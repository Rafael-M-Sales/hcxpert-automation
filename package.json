{
  "name": "hcxpert-automation",
  "version": "1.0.0",
  "description": "Projeto de automação de testes - Desafio HCXpert",
  "scripts": {
    "test": "cypress run",
    "test:chrome": "cypress run --browser chrome",
    "test:open": "cypress open",
    "test:xray": "cypress run && node scripts/upload-xray.js"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^21.0.3",
    "@cypress/webpack-preprocessor": "^6.0.2",
    "cypress": "^13.15.0",
    "dotenv": "^16.4.5",
    "webpack": "^5.95.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": "cypress/e2e/step_definitions/**/*.js",
    "html": {
      "enabled": true,
      "output": "cypress/reports/cucumber-report.html"
    },
    "json": {
      "enabled": true,
      "output": "cypress/reports/cucumber-report.json"
    }
  }
}
